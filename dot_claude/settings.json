{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/json",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "OVERRIDE_IN_SETTINGS_LOCAL_JSON",
    "OTEL_EXPORTER_OTLP_HEADERS": "OVERRIDE_IN_SETTINGS_LOCAL_JSON",
    "OTEL_LOG_USER_PROMPTS": "1",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_RESOURCE_ATTRIBUTES": "OVERRIDE_IN_SETTINGS_LOCAL_JSON"
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(xh:*)",
      "Bash(grepai:*)",
      "Bash(mise:*)",
      "Bash(brew:*)",
      "Bash(chezmoi:*)",
      "Bash(ollama:*)",
      "Bash(claude mcp:*)",
      "Bash(python3:*)",
      "Bash(uvx:*)",
      "Bash(go:*)",
      "Bash(java:*)",
      "Bash(ls:*)",
      "Bash(ps:*)",
      "Bash(env)",
      "Bash(command -v:*)",
      "Bash(chmod:*)",
      "Bash(pbcopy)",
      "Bash(lsof:*)",
      "Bash(mdfind:*)",
      "Bash(osascript:*)",
      "Bash(defaults read:*)",
      "Bash(system_profiler:*)",
      "Bash(exiftool:*)",
      "Bash(copilot:*)",
      "Bash(gemini:*)",
      "Bash(katana:*)",
      "Bash(ghq root:*)",
      "Bash(plutil:*)",
      "Bash(nvr:*)",
      "Bash(pip3 list:*)",
      "Bash(pipx list:*)",
      "Bash(wezterm cli list:*)",
      "Bash(pkill:*)",
      "Bash(pgrep:*)",
      "Bash(kill:*)",
      "WebSearch",
      "WebFetch",
      "Skill(naming-review)",
      "Skill(session-retrospective)",
      "Skill(url-digest)",
      "mcp__chrome-devtools__new_page",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__plugin_serena_serena__list_dir",
      "mcp__plugin_serena_serena__activate_project",
      "mcp__plugin_serena_serena__read_file"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm --recursive --force:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/check-editorconfig.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/biome-fix.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/go-lint-fix.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/terraform-fmt.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/tmux-status-clear.sh"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion|ExitPlanMode|EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify-stop.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify-stop.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pushcut-hook.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify-stop.sh"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify-stop.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify-stop.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true
  },
  "outputStyle": "Explanatory",
  "language": "Japanese",
  "effortLevel": "high"
}
